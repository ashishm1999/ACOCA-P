# ACOCA-P — environment configuration template
# Copy to .env before running `make up`.

# --- Storage ---
MONGO_URI=mongodb://mongo:27017/acoca
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=acoca
POSTGRES_USER=acoca
POSTGRES_PASSWORD=changeme

# --- CAPME (Context Access Probability Monitoring Engine) ---
CAPME_PORT=8081
CAPME_LEARNING_RATE=0.001
CAPME_DISCOUNT_FACTOR=0.95
CAPME_EPSILON_START=1.0
CAPME_EPSILON_MIN=0.01
CAPME_EPSILON_DECAY=0.995
CAPME_BATCH_SIZE=32
CAPME_REPLAY_CAPACITY=10000
CAPME_TARGET_SYNC_STEPS=100

# --- CFMS (Context Freshness Monitoring System) ---
CFMS_PORT=8082
CFMS_KAPPA=1.5
CFMS_WINDOW_SIZE=100
CFMS_LAMBDA_DECAY=0.01

# --- DCMF (Dynamic Context Monitoring Framework) ---
DCMF_PORT=8083
DCMF_GRPC_PORT=9083
DCMF_ALPHA_EWMA=0.60
DCMF_BETA_UTILITY=0.50
DCMF_BELIEF_THRESHOLD=0.6

# --- VACF (Volatility-Aware Context Caching Framework) ---
VACF_PORT=8084
VACF_GRPC_PORT=9084
VACF_TAU_MIN_S=30
VACF_TAU_MAX_S=300
VACF_ALPHA=1.5
VACF_P_NORM=1
VACF_R_MIN=1
VACF_R_MAX=3
VACF_TELEMETRY_INTERVAL_S=60

# --- ECCF (Edge Context Caching Framework) ---
ECCF_PORT=8085
ECCF_GRPC_PORT=9085
ECCF_T_GOSSIP_S=2
ECCF_T_SYNC_S=60
ECCF_CMS_WIDTH=1024
ECCF_CMS_DEPTH=4
ECCF_STABILITY_ALPHA=0.3
ECCF_RATE_BETA=0.5
